{
  "manifest_version": 3,
  "name": "Subtitle Vocab Companion",
  "version": "0.1.3",
  "description": "Save subtitle vocabulary from Netflix for personal study, with English/Chinese context and Language Reactor dictionary notes.",
  "permissions": [
    "storage",
    "contextMenus",
    "commands"
  ],
  "host_permissions": [
    "*://www.netflix.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.netflix.com/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Subtitle Vocab Companion"
  },
  "commands": {
    "save-word": {
      "suggested_key": {
        "default": "Alt+Shift+S"
      },
      "description": "Save selected word/phrase"
    }
  }
}
